OPENPROJECT_DATABASE_URL=postgresql+asyncpg://openproject:openproject@localhost:5432/openproject
OPENPROJECT_OLLAMA_HOST=http://localhost:11434
OPENPROJECT_OLLAMA_TIMEOUT_SECONDS=120
OPENPROJECT_LLM_MODEL=qwen2.5:14b-instruct
OPENPROJECT_EMBEDDING_MODEL=bge-m3
OPENPROJECT_EMBEDDING_DIM=1024
OPENPROJECT_EXTRACTION_MAX_CHARS=12000
OPENPROJECT_CHAT_RETRIEVAL_LIMIT=5
OPENPROJECT_CHAT_HISTORY_MAX_CHARS=4000
# Comma-separated list of allowed origins; safe as * only when the backend is bound to localhost
OPENPROJECT_CORS_ALLOW_ORIGINS=*
OPENPROJECT_LOG_LEVEL=INFO
OPENPROJECT_LOG_DIR=logs
OPENPROJECT_LOG_SQL_QUERIES=false
OPENPROJECT_LOG_LLM_INTERACTIONS=true
OPENPROJECT_LOG_LLM_PREVIEW_CHARS=200
